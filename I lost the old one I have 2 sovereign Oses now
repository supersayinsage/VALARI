                self.soul.gate = int(cmd.split()[1])
                self.ruri.log(f"Transited to Gate {self.soul.gate}")
            elif cmd == "invent":
                res = self.soul.execute_invention(7) # Code Core
                print(res)
            elif cmd == "seal":
