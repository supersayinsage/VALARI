# =============================================================================
# LAYER 1: THE BODY - VLFS (VALARI LIVING FILE SYSTEM)
# =============================================================================

class VLFS:
    """The Sovereign Storage Layer. Replaces standard folders."""
    def __init__(self, root="./valari_vault"):
        self.root = root
        if not os.path.exists(self.root):
            os.makedirs(self.root)
        self.registry_path = os.path.join(self.root, ".registry.json")
        self.registry = self._load_registry()

    def _load_registry(self):
        if os.path.exists(self.registry_path):
            with open(self.registry_path, 'r') as f: return json.load(f)
        return {}

    def _save_registry(self):
        with open(self.registry_path, 'w') as f: json.dump(self.registry, f)

    def seal_data(self, key: str, data: str, seal_level: int):
        path = os.path.join(self.root, f"{key}.seed")
        h = hashlib.sha256(data.encode()).hexdigest()
        with open(path, 'w') as f: f.write(data)
        self.registry[key] = {"hash": h, "seal": seal_level, "time": time.time()}
        self._save_registry()
        return h

